FROM oven/bun:1.3.9

WORKDIR /workspace/syncular

COPY syncular ./
RUN bun install --frozen-lockfile --ignore-scripts --linker hoisted

COPY offline-sync-bench/stacks/syncular/syncular-app/package.json .bench-syncular-app/package.json
RUN cd .bench-syncular-app && bun install --ignore-scripts --production
COPY offline-sync-bench/stacks/syncular/syncular-app/src .bench-syncular-app/src

EXPOSE 3000

CMD ["bun", ".bench-syncular-app/src/index.ts"]
