{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "services/bench-admin/src/**/*.ts",
    "services/livestore-bench-app/src/**/*.ts",
    "services/replicache-bench-app/src/**/*.ts",
    "stacks/syncular/syncular-app/src/**/*.ts",
    "services/zero-bench-app/src/**/*.ts",
    "services/powersync-bench-app/src/**/*.ts"
  ]
}
